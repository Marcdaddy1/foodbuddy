# Copy to .env and fill in. All VITE_* values are bundled into the client — treat them as public.

# Supabase project URL (Supabase dashboard -> Project Settings -> API)
VITE_SUPABASE_URL=

# Supabase anon/public API key (safe for client use; row-level security enforces access)
VITE_SUPABASE_ANON_KEY=

# Sentry DSN for crash/error reporting (Sentry -> Project Settings -> Client Keys)
VITE_SENTRY_DSN=

# PostHog project API key for product analytics (PostHog -> Project Settings)
VITE_POSTHOG_KEY=

# PostHog ingestion host (EU cloud default)
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# NOTE: Never put OpenAI (or any AI provider) keys in client env.
# AI calls go through Supabase Edge Functions; store keys as Edge Function
# secrets: supabase secrets set OPENAI_API_KEY=...
